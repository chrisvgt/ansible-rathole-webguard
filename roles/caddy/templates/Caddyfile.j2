# File Managed by Ansible
# roles/caddy/templates/Caddyfile.j2

# Global Caddy Options
{
    {% if enable_coraza_waf %}
    order coraza_waf first
    {% endif %}

    {% if enable_crowdsec %}
    crowdsec {
        api_url http://{{ crowdsec_lapi_ip }}:{{ crowdsec_lapi_port }}
        api_key {{ crowdsec_api_key }}
        ticker_interval {{ crowdsec_ticker_interval }}
        appsec_url http://{{ crowdsec_appsec_ip }}:{{ crowdsec_appsec_port }}
    }
    {% endif %}

    {% if enable_cloudflare %}
    acme_dns cloudflare {{ cloudflare_api_token }}
    {% endif %}

    # HTTPS binding: Caddy auto-enables HTTPS on port 443; HTTP on port 80 redirects to HTTPS
    auto_https on
    http_port 80
    https_port 443

    log {
        output stderr
        level INFO
    }
}

# Site-specific configurations from `caddy_sites` variable
{% for site in caddy_sites %}
{{ site.domain }} {

    # The 'route' block guarantees the strict execution order of your security pipeline.
    # Traffic cannot reach the reverse_proxy without surviving Coraza, CrowdSec, and AppSec first.
    route {
        {% if enable_coraza_waf %}
        # 1. Coraza WAF: catches malformed requests, SQLi, XSS
        coraza_waf {
            load_owasp_crs
            directives `
                Include @coraza.conf-recommended
                Include @crs-setup.conf.example
                Include @owasp_crs/REQUEST-*.conf
                SecRequestBodyLimit 20971520
                SecRequestBodyInMemoryLimit 5242880
                SecResponseBodyAccess Off
                SecAuditEngine Off
            `
        }
        {% endif %}

        {% if enable_crowdsec %}
        # 2. CrowdSec: blocks known bad IPs
        crowdsec

        # 3. CrowdSec AppSec: deep behavior/application inspection
        appsec
        {% endif %}

        # 4. Reverse Proxy: Only clean, encrypted traffic reaches this point
        {% if site.enable_forward is defined and site.enable_forward %}
        # Route specific paths to different backends when configured
        @forward_path path {{ site.forward_path }}*
        reverse_proxy @forward_path localhost:{{ site.forward_path_port | default(site.local_port) }} {
            header_up X-Forwarded-For {{ site.forward_ip }}
        }
        {% endif %}

        # Default proxy for all other paths
        reverse_proxy localhost:{{ site.local_port }} {
            header_up X-Forwarded-For {remote}
            header_up X-Request-ID {http.request.uuid}
        }
    }

    # Security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        # Enable XSS protection in older browsers
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Feature policy / Permissions policy
        Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
    }

    # Rate limiting: Higher default for streaming clients (Jellyfin makes many small requests)
    rate_limit {{ site.rate_limit | default('500r/s') }} {
        key "{http.request.remote.ip}"
        status 429
    }

    # Caching headers for static media/metadata to reduce requests
    @static_assets path /Items/* /Images/* /web/* *.js *.css *.jpg *.png *.gif
    header @static_assets Cache-Control "public, max-age=86400"
    header @static_assets ETag {http.response.header.ETag}

    # Access logging for this site
    log {
        format json
        output file {{ site.log_file | default('/var/log/caddy/' + site.name + '.access.log') }} {
            roll_size {{ site.log_roll_size | default('10mb') }}
            roll_keep {{ site.log_roll_keep | default(10) }}
            roll_keep_for {{ site.log_roll_keep_for | default('36h') }}
        }
    }
}

{% endfor %}
